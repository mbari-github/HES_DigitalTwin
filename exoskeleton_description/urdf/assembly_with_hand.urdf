<?xml version='1.0' encoding='utf-8'?>

<robot name="urdf_assembly">

    <link name="base_link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size="0.01 0.01 0.01"/>
            </geometry>
        </visual>
    </link> 
    
    <link name="body">
        <inertial>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0" />
            <mass value="0.1223" />
            <inertia ixx="5.91121e-05" iyy="7.75083e-06" izz="5.56796e-05" ixy="-8.991e-12" iyz="-1.287e-06" ixz="-1.43744e-12" />
        </inertial>
        <visual name="body_visual">
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0" />
            <geometry>
                <mesh filename="package://exoskeleton_description/meshes/body.stl" scale="0.001 0.001 0.001" />
            </geometry>
        </visual>
        <collision name="body_collision">
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0" />
            <geometry>
                <mesh filename="package://exoskeleton_description/meshes/body.stl" scale="0.001 0.001 0.001" />
            </geometry>
        </collision>
    </link>

    <link name="link_AC">
        <inertial>
            <origin xyz="0.0222 -0.008172 0.0" rpy="0.0 0.0 0.0" />
            <mass value="0.06234" />
            <inertia ixx="1.15274e-05" iyy="9.5782e-06" izz="2.01595e-05" ixy="6.5499e-06" iyz="7.12e-08" ixz="-4.923e-08" />
        </inertial>
        <visual name="link_AC_visual">
            <origin xyz="0.007356 0.008556 0.0" rpy="-2.9131 -1.5708 0.0" />
            <geometry>
                <mesh filename="package://exoskeleton_description/meshes/link_AC.stl" scale="0.001 0.001 0.001" />
            </geometry>
        </visual>
        <collision name="link_AC_collision">
            <origin xyz="0.007356 0.008556 0.0" rpy="-2.9131 -1.5708 0.0" />
            <geometry>
                <mesh filename="package://exoskeleton_description/meshes/link_AC.stl" scale="0.001 0.001 0.001" />
            </geometry>
        </collision>
    </link>

    <link name="rear_crank">
        <inertial>
            <origin xyz="0.01361 0.007049 -0.000762" rpy="0.0 0.0 0.0" />
            <mass value="0.02908" />
            <inertia ixx="1.70292e-06" iyy="3.98339e-06" izz="4.76408e-06" ixy="-1.7956e-06" iyz="-1.13744e-07" ixz="-2.04e-07" />
        </inertial>
