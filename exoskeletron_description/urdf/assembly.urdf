<?xml version='1.0' encoding='utf-8'?>

<robot name="urdf_assembly">

    <link name="base_link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size="0.01 0.01 0.01"/>
            </geometry>
        </visual>
    </link> 
    
    <link name="body">
        <inertial>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0" />
            <mass value="0.1223" />
            <inertia ixx="5.91121e-05" iyy="7.75083e-06" izz="5.56796e-05" ixy="-8.991e-12" iyz="-1.287e-06" ixz="-1.43744e-12" />
        </inertial>
        <visual name="body_visual">
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0" />
            <geometry>
                <mesh filename="package://exoskeletron_description/meshes/body.stl" scale="0.001 0.001 0.001" />
            </geometry>
        </visual>
        <collision name="body_collision">
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0" />
            <geometry>
                <mesh filename="package://exoskeletron_description/meshes/body.stl" scale="0.001 0.001 0.001" />
            </geometry>
        </collision>
    </link>

    <link name="link_AC">
        <inertial>
            <origin xyz="0.0222 -0.008172 0.0" rpy="0.0 0.0 0.0" />
            <mass value="0.06234" />
            <inertia ixx="1.15274e-05" iyy="9.5782e-06" izz="2.01595e-05" ixy="6.5499e-06" iyz="7.12e-08" ixz="-4.923e-08" />
        </inertial>
        <visual name="link_AC_visual">
            <origin xyz="0.007356 0.008556 0.0" rpy="-2.9131 -1.5708 0.0" />
            <geometry>
                <mesh filename="package://exoskeletron_description/meshes/link_AC.stl" scale="0.001 0.001 0.001" />
            </geometry>
        </visual>
        <collision name="link_AC_collision">
            <origin xyz="0.007356 0.008556 0.0" rpy="-2.9131 -1.5708 0.0" />
            <geometry>
                <mesh filename="package://exoskeletron_description/meshes/link_AC.stl" scale="0.001 0.001 0.001" />
            </geometry>
        </collision>
    </link>

    <link name="rear_crank">
        <inertial>
            <origin xyz="0.01361 0.007049 -0.000762" rpy="0.0 0.0 0.0" />
            <mass value="0.02908" />
            <inertia ixx="1.70292e-06" iyy="3.98339e-06" izz="4.76408e-06" ixy="-1.7956e-06" iyz="-1.13744e-07" ixz="-2.04e-07" />
        </inertial>
        <visual name="rear_crank_visual">
            <origin xyz="0.0171 -0.0588 0.0" rpy="-2.8798 -1.5708 0.0" />
            <geometry>
                <mesh filename="package://exoskeletron_description/meshes/rear_crank.stl" scale="0.001 0.001 0.001" />
            </geometry>
        </visual>
        <collision name="rear_crank_collision">
            <origin xyz="0.0171 -0.0588 0.0" rpy="-2.8798 -1.5708 0.0" />
            <geometry>
                <mesh filename="package://exoskeletron_description/meshes/rear_crank.stl" scale="0.001 0.001 0.001" />
            </geometry>
        </collision>
    </link>

    <link name="connecting_rod">
        <inertial>
            <origin xyz="-0.006793 -0.03467 0.0" rpy="0.0 0.0 0.0" />
            <mass value="0.03844" />
            <inertia ixx="1.55767e-05" iyy="1.21347e-06" izz="1.663e-05" ixy="-2.90187e-06" iyz="0.0" ixz="0.0" />
        </inertial>
        <visual name="connecting_rod_visual">
            <origin xyz="-0.03087 -0.06882 0.0" rpy="-3.132 -1.5708 0.0" />
            <geometry>
                <mesh filename="package://exoskeletron_description/meshes/connecting_rod.stl" scale="0.001 0.001 0.001" />
            </geometry>
        </visual>
        <collision name="connecting_rod_collision">
            <origin xyz="-0.03087 -0.06882 0.0" rpy="-3.132 -1.5708 0.0" />
            <geometry>
                <mesh filename="package://exoskeletron_description/meshes/connecting_rod.stl" scale="0.001 0.001 0.001" />
            </geometry>
        </collision>
    </link>


    <!--  NUOVI LINK E JOINT FISSI PER IL VINCOLO DI CHIUSURA  -->

    <!-- punto di chiusura su link_AC -->
    <link name="frame_AC_end">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <sphere radius="0.001"/>
            </geometry>
            <material name="blue">
                <color rgba="0 0 1 1"/>
            </material>
        </visual>
    </link>

    <joint name="fixed_AC_end" type="fixed">
        <parent link="link_AC"/>
        <child link="frame_AC_end"/>
        <origin xyz="0.02446 0.01180 0.0" rpy="0.0 0.0 0.0"/>
    </joint>

    <!-- punto di chiusura su connecting_rod -->
    <link name="frame_rod_end">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <sphere radius="0.001"/>
            </geometry>
            <material name="red">
                <color rgba="1 0 0 1"/>
            </material>
        </visual>
    </link>

    <joint name="fixed_rod_end" type="fixed">
        <parent link="connecting_rod"/>
        <child link="frame_rod_end"/>
        <origin xyz="-0.013442 -0.069321 -5.1062e-7" rpy="0 0 0"/>
    </joint>


<!--   JOINTS ORIGINALI   -->

    <joint name="rev_crank" type="revolute">
        <origin xyz="0.0 -0.05876 -0.0008932" rpy="-3.1416 -1.5708 0.0" />
        <parent link="body" />
        <child link="rear_crank" />
        <axis xyz="0.0 0.0 1.0" />
        <limit lower="-3.1416" upper="3.1416" effort="1000000" velocity="1000000" />
    </joint>

    <joint name="body_fixed" type="fixed">
        <parent link="base_link"/>
        <child link="body"/>
        <origin xyz="0 0 0.025" rpy="0 0 0"/>
    </joint>

    <joint name="rev_body2linkAC" type="revolute">
        <origin xyz="0.0 0.006701 -0.0089853" rpy="-3.1416 -1.5708 0.0" />
        <parent link="body" />
        <child link="link_AC" />
        <axis xyz="0.0 0.0 1.0" />
        <limit lower="-3.1416" upper="3.1416" effort="1000000" velocity="1000000" />
    </joint>

    <joint name="rev_crank2shaft" type="revolute">
        <origin xyz="0.02981 0.01566 0.0" rpy="0.0 0.0 0.0" />
        <parent link="rear_crank" />
        <child link="connecting_rod" />
        <axis xyz="0.0 0.0 1.0" />
        <limit lower="-3.1416" upper="3.1416" effort="1000000" velocity="1000000" />
    </joint>

<!-- #########################################-->

    <!-- LINKS -->

    <link name="slider_f">
        <inertial>
            <origin xyz="0.0002343 0.006014 0.00348" rpy="0.0 0.0 0.0" />
            <mass value="0.006394" />
            <inertia ixx="5.42365e-08" iyy="1.50739e-07" izz="1.63551e-07" ixy="0.0" iyz="0.0" ixz="0.0" />
        </inertial>
        <visual name="slider_f_visual">
            <origin xyz="-0.0075 -0.0275 -0.00875" rpy="-2.8947 0.0 0.0" />
            <geometry>
                <mesh filename="package://exoskeletron_description/meshes/slider_f.stl" scale="0.001 0.001 0.001" />
            </geometry>
        </visual>
        <collision name="slider_f_collision">
            <origin xyz="-0.0075 -0.0275 -0.00875" rpy="-2.8947 0.0 0.0" />
            <geometry>
                <mesh filename="package://exoskeletron_description/meshes/slider_f.stl" scale="0.001 0.001 0.001" />
            </geometry>
        </collision>
    </link>

    <link name="link_BC">
        <inertial>
            <origin xyz="0 0 0" rpy="0.0 0.0 0.0" />
            <mass value="0.01155" />
            <inertia ixx="1.10976e-05" iyy="1.53689e-06" izz="1.26268e-05" ixy="-2.99251e-06" iyz="0.0" ixz="0.0" />
        </inertial>
        <visual name="link_BC_visual">
            <origin xyz="0.004365 0.03241 -0.008" rpy="0.08988 1.5708 0.0" />
            <geometry>
                <mesh filename="package://exoskeletron_description/meshes/link_BC.stl" scale="0.001 0.001 0.001" />
            </geometry>
        </visual>
        <collision name="link_BC_collision">
            <origin xyz="0.004365 0.03241 -0.008" rpy="0.08988 1.5708 0.0" />
            <geometry>
                <mesh filename="package://exoskeletron_description/meshes/link_BC.stl" scale="0.001 0.001 0.001" />
            </geometry>
        </collision>
    </link> 
    

    <!-- JOINTS-->

    <joint name="slider" type="prismatic">
        <origin xyz="0.0 -0.037468 0.00023484" rpy="2.8861 0.0 0.0" /> 
        <parent link="body" />
        <child link="slider_f" />
        <axis xyz="0.0 1.0 0.0" />
        <limit lower="-0.0095" upper="0.0095" effort="1000000" velocity="1000000" />
    </joint>

    <joint name="rev_slider2linkBC" type="revolute">
        <origin xyz="0 0 0" rpy="-1.5708 1.3153 1.5708" />
        <parent link="slider_f" />
        <child link="link_BC" />
        <axis xyz="0.0 0.0 1.0" />
        <limit lower="-3.1416" upper="3.1416" effort="1000000" velocity="1000000" />
    </joint> 



     <!-- punto di chiusura su link_AC -->
    <link name="frame_AC_end_2">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <sphere radius="0.001"/>
            </geometry>
            <material name="blue">
                <color rgba="0 0 1 1"/>
            </material>
        </visual>
    </link>

    <joint name="fixed_AC_end_2" type="fixed">
        <parent link="link_AC"/>
        <child link="frame_AC_end_2"/>
        <origin xyz="0.0430 -0.03828 0" rpy="0.0 0.0 0.0"/>
    </joint>


    <!-- punto di chiusura su link_BC -->
    <link name="frame_BC_end">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <sphere radius="0.001"/>
            </geometry>
            <material name="blue">
                <color rgba="0 0 1 1"/>
            </material>
        </visual>
    </link>

    <joint name="fixed_BC_end" type="fixed">
        <parent link="link_BC"/>
        <child link="frame_BC_end"/>
        <origin xyz="0.03378016 0.082449 4.4124e-7" rpy="3.1416 0.0 0.0"/>
    </joint>



    <!-- FIN QUI FUNZIONA TUTTO-->
<!-- ############################################################## -->

    <!-- LINKS -->

    <link name="link_CE">
        <inertial>
            <origin xyz="-0.02316 -0.0166 0.000506" rpy="0.0 0.0 0.0" />
            <mass value="0.005995" />
            <inertia ixx="5.16e-07" iyy="1.80331e-06" izz="2.27595e-06" ixy="-8.82461e-07" iyz="-2.50712e-08" ixz="-4.76815e-08" />
        </inertial>
        <visual name="link_CE_visual">
            <origin xyz="-0.03204 0.04956 -0.001" rpy="-2.9908 -1.5708 0.0" />
            <geometry>
                <mesh filename="package://exoskeletron_description/meshes/link_CE.stl" scale="0.001 0.001 0.001" />
            </geometry>
        </visual>
        <collision name="link_CE_collision">
            <origin xyz="-0.03204 0.04956 -0.001" rpy="-2.9908 -1.5708 0.0" />
            <geometry>
                <mesh filename="package://exoskeletron_description/meshes/link_CE.stl" scale="0.001 0.001 0.001" />
            </geometry>
        </collision>
    </link>

    <!-- JOINTS -->


    <joint name="rev_linkAC2linkCE" type="revolute">
        <origin xyz="0.04298 -0.03828 0.0" rpy="0.0 0.0 0.0" />
        <parent link="link_AC" />
        <child link="link_CE" />
        <axis xyz="0.0 0.0 1.0" />
        <limit lower="-3.1416" upper="3.1416" effort="1000000" velocity="1000000" />
    </joint>


    <!-- CHIUSURE -->
    <link name="frame_CE_end">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <sphere radius="0.001"/>
            </geometry>
            <material name="blue">
                <color rgba="0 0 1 1"/>
            </material>
        </visual>
    </link>

    <joint name="fixed_CE_end" type="fixed">
        <parent link="link_CE"/>
        <child link="frame_CE_end"/>
        <origin xyz="-0.007428 -0.008328 0.0" rpy="0.0 0.0 0.0" />
    </joint>


    <link name="frame_BC_end_2">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <sphere radius="0.001"/>
            </geometry>
            <material name="blue">
                <color rgba="0 0 1 1"/>
            </material>
        </visual>
    </link>

    <joint name="fixed_BC_end_2" type="fixed">
        <parent link="link_BC"/>
        <child link="frame_BC_end_2"/>
        <origin xyz="0.02633216 0.090777 4.1981e-7" rpy="3.1416 0.0 0.0" />
    </joint>





    <link name="frame_CE_end_2">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <sphere radius="0.001"/>
            </geometry>
            <material name="blue">
                <color rgba="0 0 1 1"/>
            </material>
        </visual>
    </link>

    <joint name="fixed_CE_end_2" type="fixed">
        <parent link="link_CE"/>
        <child link="frame_CE_end_2"/>
        <origin xyz="-0.0531 -0.02751 -3.9714e-7" rpy="0.0 -1.5708 0.0" />
    </joint>


</robot>
